<ui:FluentWindow
    x:Class="Helinstaller.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Helinstaller.Views.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"

    Title="{Binding ViewModel.ApplicationTitle, Mode=OneWay}"
    Width="1100"
    Height="650"
    d:DataContext="{d:DesignInstance local:MainWindow,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    WindowBackdropType="Tabbed"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    
    
    mc:Ignorable="d" ResizeMode="NoResize" MaxHeight="650" MaxWidth="1100" ExtendsContentIntoTitleBar="True" Initialized="FluentWindow_Initialized">
    <Grid>
        <Grid x:Name="MainGrid" Visibility="Hidden" Opacity="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            


            <ui:NavigationView
            x:Name="RootNavigation"
            Grid.Row="1"
            Padding="10,0,10,0"
            BreadcrumbBar="{Binding ElementName=BreadcrumbBar}"
            FooterMenuItemsSource="{Binding ViewModel.FooterMenuItems, Mode=OneWay}"
            FrameMargin="5"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleVisible="True"
            IsPaneOpen="False"
            MenuItemsSource="{Binding ViewModel.MenuItems, Mode=OneWay}"
            PaneDisplayMode="Left" TransitionDuration="500" Transition="FadeIn" OpenPaneLength="200">
                <ui:NavigationView.Header>

                    <ui:BreadcrumbBar x:Name="BreadcrumbBar" Margin="42,32,42,20" Visibility="Collapsed"/>
                </ui:NavigationView.Header>
                <ui:NavigationView.ContentOverlay>
                    <Grid x:Name="ContentGrid">
                        <ui:SnackbarPresenter x:Name="SnackbarPresenter"/>
                    </Grid>
                </ui:NavigationView.ContentOverlay>

            </ui:NavigationView>


            <ContentPresenter
            x:Name="RootContentDialog"
            Grid.Row="0"
            Grid.RowSpan="2"/>

            <ui:TitleBar
    x:Name="TitleBar"
    Title="{Binding ViewModel.ApplicationTitle}"
    Grid.Row="0"
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Center"
    CloseWindowByDoubleClickOnIcon="True" 
    ShowMaximize="False">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="/Assets/wpfui-icon.ico"/>
                </ui:TitleBar.Icon>
                <ui:TitleBar.CenterContent>
                    <!-- НЕВИДИМЫЙ ТРИГГЕР (Датчик мыши) -->
                    <Border x:Name="HubTrigger"
                Background="Transparent"
                Width="220" Height="40"
                MouseEnter="HubTrigger_MouseEnter" />
                </ui:TitleBar.CenterContent>
                <ui:TitleBar.TrailingContent>
                    <ui:Button BorderBrush="Transparent" Background="Transparent" Appearance="Transparent" Width="42" Height="30" Padding="0" VerticalAlignment="Top" Margin="0,0,0,0" Click="Donate_Click">
                        <ui:SymbolIcon Filled="True" Symbol="Heart48" Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <!-- Border — это и есть фон нашей кнопки -->
                                <Border x:Name="border" 
                    Background="{TemplateBinding Background}" 
                    BorderThickness="0" 
                    SnapsToDevicePixels="true">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <!-- Эффект при наведении (как у кнопки свернуть) -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <!-- #1AFFFFFF — это белый цвет с прозрачностью 10%. 
                         Дает тот самый эффект "подсветки" на темном фоне -->
                                        <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                                    </Trigger>

                                    <!-- Эффект при нажатии -->
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>

                    </ui:Button>
                </ui:TitleBar.TrailingContent>
            </ui:TitleBar>
            <Border x:Name="HubCard" 
Grid.Row="0" Grid.RowSpan="2"
WindowChrome.IsHitTestVisibleInChrome="True"
HorizontalAlignment="Center" 
VerticalAlignment="Top"
Margin="0,7,0,0" 
Width="180" Height="40" 
CornerRadius="20" 
Panel.ZIndex="9999"
IsHitTestVisible="True" 
MouseEnter="HubCard_MouseEnter" 
MouseLeave="HubCard_MouseLeave" 
SizeChanged="HubCard_SizeChanged"
>

                <Grid>
                    <Border x:Name="HubBorder" 
        CornerRadius="20" 
        ClipToBounds="True"
        Background="Black"
        RenderTransformOrigin="0.5,0.5">


                        <Grid Visibility="Hidden">
                            <Border x:Name="MaskConstraint" 
                Background="Black"
                
                CornerRadius="20"
                Width="{Binding ElementName=HubBorder, Path=ActualWidth}"
                Height="{Binding ElementName=HubBorder, Path=ActualHeight}"/>
                        </Grid>
                    </Border>

                    <Grid Margin="10,6,10,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ВЕРХНЯЯ ПАНЕЛЬ (Видна всегда) -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <!-- Сделали колонку чуть шире, чтобы волнам было куда расходиться -->
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 1. НОВЫЙ КОНТЕЙНЕР АВАТАРКИ (Сабвуфер) -->
                            <Grid Grid.Column="0" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Кольцо ударной волны -->
                                <Ellipse x:Name="AvatarRing" Fill="{DynamicResource SystemAccentColorPrimaryBrush}" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform x:Name="RingScale" ScaleX="1" ScaleY="1"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Effect>
                                        <BlurEffect Radius="10"/>
                                    </Ellipse.Effect>
                                </Ellipse>

                                <!-- Сама картинка -->
                                <ui:Image x:Name="Picture" Width="28" Height="28" CornerRadius="14" RenderTransformOrigin="0.5,0.5">
                                    <ui:Image.RenderTransform>
                                        <ScaleTransform x:Name="AvatarScale" ScaleX="1" ScaleY="1"/>
                                    </ui:Image.RenderTransform>
                                </ui:Image>
                            </Grid>

                            <!-- 2. ИДЕАЛЬНО ЧИСТЫЙ ТЕКСТ -->
                            <Grid Grid.Column="1" Margin="5,0">
                                <Grid x:Name="LyricsOuterContainer" VerticalAlignment="Center">
                                    <ui:TextBlock x:Name="LyricsDisplay"
                          FontSize="14" 
                          Foreground="White"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center" 
                          TextAlignment="Center"
                          TextWrapping="NoWrap"
                          Opacity="0"
                          RenderTransformOrigin="0.5,0.5">
                                        <ui:TextBlock.Effect>
                                            <DropShadowEffect BlurRadius="10" Direction="0" Opacity="0.5"/>
                                        </ui:TextBlock.Effect>
                                    </ui:TextBlock>
                                </Grid>
                            </Grid>

                            <Grid Grid.Column="2" Width="24" Height="24" VerticalAlignment="Center" Margin="5,0,0,0">
                                <!-- Иконка музыки (видна по умолчанию) -->
                                <ui:SymbolIcon x:Name="MusicIcon" Symbol="MusicNote216" FontSize="18" Foreground="White" 
                    VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Прогресс-ринг загрузок (скрыт по умолчанию) -->
                                <ui:ProgressRing x:Name="DownloadProgressRing" Width="20" Height="20" 
                      IsIndeterminate="True" Opacity="0" 
                      VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Зеленая галочка успеха (скрыта по умолчанию) -->
                                <ui:SymbolIcon x:Name="SuccessIcon" Symbol="Checkmark24" FontSize="18" Foreground="LightGreen" 
                    Opacity="0" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Красный крестик ошибки (скрыта по умолчанию) -->
                                <ui:SymbolIcon x:Name="ErrorIcon" Symbol="Dismiss24" FontSize="18" Foreground="#FFFC3D39" 
                    Opacity="0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                        </Grid>

                        <!-- ПЛЕЕР (Скрыт по дефолту) -->
                        <Grid x:Name="playerBadge" Grid.Row="1" Margin="0,10,0,0" Opacity="0" IsHitTestVisible="False">
                            <StackPanel Orientation="Vertical">
                                <!-- Заголовок берем только из имени файла -->
                                <ui:TextBlock x:Name="ArtistTitle" Text="" Appearance="Tertiary" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <ui:TextBlock x:Name="SongTitle" Text="..." FontSize="14" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="280"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
                                    <ui:Button x:Name="PrevButton" Width="36" Height="36" Margin="5,0" Appearance="Secondary" Click="PrevButton_Click" CornerRadius="18">
                                        <ui:SymbolIcon Symbol="Previous48" Filled="True"/>
                                    </ui:Button>
                                    <ui:Button x:Name="PlayPauseButton" Width="44" Height="44" Margin="5,0" Appearance="Primary" Click="PlayPauseButton_Click" CornerRadius="22">
                                        <ui:SymbolIcon x:Name="PlayIcon" Symbol="Play48" Filled="True"/>
                                    </ui:Button>
                                    <ui:Button x:Name="NextButton" Width="36" Height="36" Margin="5,0" Appearance="Secondary" Click="NextButton_Click" CornerRadius="18">
                                        <ui:SymbolIcon Symbol="Next48" Filled="True"/>
                                    </ui:Button>
                                </StackPanel>
                                <ProgressBar x:Name="songProgress" Height="4" Margin="10,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
            

        </Grid>
        <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center">
            <ui:TextBlock x:Name="desc" TextWrapping="Wrap" Text="Подключение..." FontSize="24" HorizontalAlignment="Center" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,20"/>
            <ui:SymbolIcon x:Name="stat" MaxHeight="60" MaxWidth="60" Visibility="Collapsed" Symbol="CloudCheckmark48" VerticalAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.AccentColorBrushKey}}" FontSize="64"/>
            <ui:ProgressRing x:Name="ring" MaxHeight="60" MaxWidth="60" IsIndeterminate="True" VerticalAlignment="Center"/>
            <ProgressBar x:Name="loadingBar" Maximum="3" Width="340" Margin="0,25,0,0"/>
        </StackPanel>
        <ui:TextBox Opacity="0.3" x:Name="info" Margin="0,10,0,0" TextChanged="info_TextChanged" Visibility="Hidden" HorizontalContentAlignment="Center" PlaceholderEnabled="False" ClearButtonEnabled="False" SelectionOpacity="2" IsReadOnly="True" VerticalAlignment="Bottom" HorizontalAlignment="Center" TextWrapping="WrapWithOverflow" IsTextSelectionEnabled="True" AcceptsReturn="True"/>
        
    </Grid>
    
</ui:FluentWindow>
