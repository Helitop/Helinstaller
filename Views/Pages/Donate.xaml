<Page
    x:Class="Helinstaller.Views.Pages.Donate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d" Margin="0,15,0,0"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <!-- Используем Grid вместо StackPanel -->
    <Grid Margin="20,15,20,20">
        <Grid.RowDefinitions>
            <!-- Верхняя строка подстраивается под текст -->
            <RowDefinition Height="Auto"/>
            <!-- Нижняя строка забирает всё ОСТАВШЕЕСЯ место -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TextBlock 
            Grid.Row="0"
            TextAlignment="Center" 
            Text="Буду очень благодарен поддержке проекта. QRчик на Сбер, если есть желание оставить копеечку:"  
            FontTypography="Title" 
            TextWrapping="Wrap" 
            Margin="0,0,0,20"/>

        <!-- Картинка во второй строке -->
        <ui:Image 
            Grid.Row="1"
            Source="/Assets/donation.png" 
            CornerRadius="20"
            Stretch="Uniform" 
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            MaxWidth="400"/>
        <!-- MaxWidth, чтобы на огромных мониторах QR не стал гигантским -->

    </Grid>
</Page>