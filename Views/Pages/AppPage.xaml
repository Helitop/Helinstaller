<Page
    x:Class="Helinstaller.Views.Pages.AppPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:Helinstaller.ViewModels.Pages"
    xmlns:local="clr-namespace:Helinstaller.Helpers"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance viewmodels:AppPageViewmodel, IsDesignTimeCreatable=True}"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,15,0,0" Loaded="Page_Loaded">

    <Page.Resources>
        <local:StringToVisibilityConverter x:Key="PathToVisibilityConverter"/>
        <local:StringToImageSourceConverter x:Key="ImageSourceConverter"/>
    </Page.Resources>

    <Grid Margin="20,0,20,20">
        <Grid.ColumnDefinitions>
            <!-- Левая колонка для инфы -->
            <ColumnDefinition Width="4.5*" MaxWidth="500"/>
            <ColumnDefinition Width="0.5*"/>
            <!-- Отступ -->
            <!-- Правая колонка для превью -->
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ: Информация и Кнопки -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,15,0">
            <StackPanel VerticalAlignment="Top">

                <!-- Шапка: Иконка + Заголовок -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">

                    <!-- ИСправленная Иконка (Используем ImageBrush для скругления) -->
                    <Border Width="110" Height="110" CornerRadius="20" Padding="10" Background="#0AFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" 
                            Visibility="{Binding IconPath, Converter={StaticResource PathToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3" Color="Black"/>
                        </Border.Effect>

                        <!-- Внутренний бордер рисует картинку как фон, идеально соблюдая скругления -->
                        <Border CornerRadius="19">
                            <Border.Background>
                                <ImageBrush Stretch="UniformToFill" ImageSource="{Binding IconPath, Converter={StaticResource ImageSourceConverter}}"/>
                            </Border.Background>
                        </Border>
                    </Border>

                    <StackPanel VerticalAlignment="Center" Margin="24,0,0,0">
                        <TextBlock Text="{Binding Title}" FontSize="36" FontWeight="Bold" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="Приложение" FontSize="14" Opacity="0.5" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <!-- Описание -->
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="15" Opacity="0.75" LineHeight="24" Margin="0,0,0,32" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                <!-- ПАНЕЛЬ УСТАНОВКИ -->
                <ui:Card Padding="24" Background="#0CFFFFFF" BorderBrush="#1AFFFFFF" VerticalAlignment="Top">
                    <StackPanel>
                        <!-- Главная кнопка -->
                        <ui:Button x:Name="InstallButton" 
           Height="50" FontSize="16" FontWeight="SemiBold" 
           Appearance="Primary" Command="{Binding InstallCommand}" 
           Click="InstallButton_Click" HorizontalAlignment="Stretch"
           Tag="{Binding ElementName=ForceInstallSwitch, Path=IsChecked}">
                            <!-- ВАЖНО: прокидываем статус свитча сюда! -->
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource DefaultUiButtonStyle}">
                                    <Setter Property="Content" Value="Установить" />

                                    <Style.Triggers>
                                        <!-- 1. Если установлено - блокируем -->
                                        <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                            <Setter Property="Content" Value="Установлено" />
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>

                                        <!-- 2. МАГИЯ: Если установлено И наш Tag (состояние свитча) = True -> Разблокируем -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsInstalled}" Value="True"/>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="IsEnabled" Value="True" />
                                            <Setter Property="Content" Value="Переустановить" />
                                        </MultiDataTrigger>

                                        <!-- 3. Состояния загрузки (перекрывают всё) -->
                                        <DataTrigger Binding="{Binding IsChecking}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <ui:ProgressRing Height="24" Width="24" IsIndeterminate="True" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                            <Setter Property="Content">
                                                <Setter.Value>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <ui:ProgressRing Height="20" Width="20" IsIndeterminate="False" Progress="{Binding ProgressValue}" Margin="0,0,10,0" />
                                                        <ui:TextBlock Text="Установка..." Foreground="{DynamicResource ApplicationBackgroundBrush}" VerticalAlignment="Center" FontSize="15"/>
                                                    </StackPanel>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>

                        <!-- Разделитель -->
                        <Border Height="1" Background="#1AFFFFFF" Margin="0,20,0,20"/>

                        <!-- Переключатель принудительной установки -->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <ui:ToggleSwitch x:Name="ForceInstallSwitch" VerticalAlignment="Center"/>
                                <TextBlock Text="Принудительная установка" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="Не рекомендуется. Включай, только если уверен, что программа сломана или её нужно переустановить поверх старой." 
                                       TextWrapping="Wrap" FontSize="12" Opacity="0.5" LineHeight="16" Margin="0,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- ПРАВАЯ ЧАСТЬ: Идеальное превью со скруглениями -->
        <Border Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" 
                CornerRadius="16" Background="#05FFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" 
                Visibility="{Binding PreviewPath, Converter={StaticResource PathToVisibilityConverter}}"
                Margin="0,0,0,20">
            <!-- Тень рамки -->
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.4" Color="Black" />
            </Border.Effect>

            <!-- Сама картинка. Она сама задаст правильные пропорции рамке -->
            <Image x:Name="AppPreviewImage" 
                   RenderOptions.BitmapScalingMode="HighQuality" 
                   Stretch="Uniform" 
                   Source="{Binding PreviewPath, Converter={StaticResource ImageSourceConverter}}">

                <!-- МАГИЯ: Отрезаем острые углы у самой картинки -->
                <Image.OpacityMask>
                    <VisualBrush>
                        <VisualBrush.Visual>
                            <!-- Эта маска невидима, она просто "вырезает" картинку по своим краям.
                                 Биндинг размеров гарантирует, что скругления (CornerRadius) 
                                 не исказятся и всегда будут ровными. -->
                            <Border Background="Black" CornerRadius="15" 
                                    Width="{Binding ActualWidth, ElementName=AppPreviewImage}" 
                                    Height="{Binding ActualHeight, ElementName=AppPreviewImage}" />
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Image.OpacityMask>
            </Image>
        </Border>

    </Grid>
</Page>